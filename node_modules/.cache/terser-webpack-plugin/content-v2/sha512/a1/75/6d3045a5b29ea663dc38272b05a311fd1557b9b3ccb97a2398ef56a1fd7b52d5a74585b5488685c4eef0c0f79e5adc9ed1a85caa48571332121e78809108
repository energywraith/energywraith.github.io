r\n    &:nth-of-type(2) {\r\n      top: 50%;\r\n    }\r\n\r\n    &:last-of-type {\r\n      top: 100%;\r\n      ${props => props.active && \"top: 50%; transition-delay: 0ms\"}\r\n    }\r\n  }\r\n`\r\n\r\nexport const NavLinksContainer = styled.div`\r\n  display: flex; \r\n  align-items: center;\r\n  column-gap: 5em;\r\n`\r\n\r\nconst fadeIn = keyframes`\r\n  from {\r\n    opacity: 0;\r\n  }\r\n\r\n  to {\r\n    opacity: 1;\r\n  }\r\n`\r\n\r\nexport const NavLinks = styled.ul`\r\n  padding: 0;\r\n  margin: 0;\r\n  transition: 150ms ease-out;\r\n\r\n  opacity: 0;\r\n  display: none;\r\n  column-gap: 2em;\r\n\r\n  & li a {\r\n    cursor: pointer;\r\n    padding: 1em;\r\n  }\r\n\r\n  ${props => props.active && \"opacity: 1; display: flex;\"}\r\n\r\n  @media(max-width: 600px) {\r\n    animation: ${fadeIn} 0.1s forwards;\r\n    position: absolute;\r\n    left: 0;\r\n    top: 0;\r\n    width: 100vw;\r\n    height: 100vh;\r\n    background: black;\r\n    z-index: 1;\r\n\r\n    flex-direction: column;\r\n    align-items: flex-end;\r\n    justify-content: center;\r\n    font-size: 2.5em;\r\n    row-gap: 1em;\r\n  }\r\n`","import styled from \"styled-components\"\r\n\r\nexport const BrandContainer = styled.div`\r\n  display: grid;\r\n  grid-template: 1fr 1fr / auto 1fr;\r\n  column-gap: 0.5em;\r\n  align-items: center;\r\n  width: 100%;\r\n\r\n  & img {\r\n    grid-column: 1;\r\n    grid-row: 1/3;\r\n    height: 100%;\r\n    width: auto;\r\n    border-radius: 4px;\r\n  }\r\n\r\n  & span {\r\n    font-weight: 400;\r\n    font-size: 0.8em;\r\n  }\r\n`","export default __webpack_public_path__ + \"static/media/brandLogo.73ad3568.svg\";","import React from 'react'\r\nimport { BrandContainer } from './Brand.style'\r\nimport brandIcon from '../../img/LandingPage/brandLogo.svg'\r\n\r\nconst Brand = ({ className }) => {\r\n  return (\r\n    <BrandContainer className={className}>\r\n      <img src={brandIcon} alt=\"brandIcon\" />\r\n      <span> Adam Jałocha </span>\r\n      <span> Web developer </span>\r\n    </BrandContainer>\r\n  )\r\n}\r\n\r\nexport default Brand","import { useState } from 'react'\r\nimport { Link } from \"react-scroll\";\r\nimport { NavContainer, NavLinksContainer, NavLinks, Hamburger } from './Nav.style'\r\nimport Brand from \"./Brand\";\r\n\r\nconst Nav = () => {\r\n  const [hamburgerState, setHamburgerState] = useState(false)\r\n  \r\n  const handleHamburgerClick = () => {\r\n    if(window.innerWidth < 600) {\r\n      if(!hamburgerState === true) {\r\n        document.body.style.overflowY = \"hidden\";\r\n      } else {\r\n        document.body.style.overflowY = \"scroll\";\r\n      }\r\n    }\r\n    setHamburgerState(!hamburgerState)\r\n  }\r\n\r\n  return (\r\n    <NavContainer>\r\n      <Link to=\"Home\" smooth={true} duration={500} onClick={() => setHamburgerState(false)} style={{ cursor: \"pointer\" }}>\r\n        <Brand />\r\n      </Link>\r\n\r\n      <NavLinksContainer>\r\n        <NavLinks active={hamburgerState}>\r\n          <li>\r\n            <Link to=\"Projects\" isDynamic={true} smooth={true} duration={500} onClick={() => {document.body.style.overflowY = \"scroll\"; setHamburgerState(false)}}>\r\n              Projects\r\n            </Link>\r\n          </li>\r\n          <li>\r\n            <Link to=\"Contact\" isDynamic={true} smooth={true} duration={1000} onClick={() => {document.body.style.overflowY = \"scroll\"; setHamburgerState(false)}}>\r\n              Contact\r\n            </Link>\r\n          </li>\r\n        </NavLinks>\r\n        \r\n        <Hamburger active={hamburgerState} onClick={handleHamburgerClick}>\r\n          <span /><span /><span />\r\n        </Hamburger>\r\n      </NavLinksContainer>\r\n    </NavContainer>\r\n  )\r\n}\r\n\r\nexport default Nav","import styled from \"styled-components\"\r\n\r\nexport const IntroductionContainer = styled.div`\r\n  font-size: 4em;\r\n  padding: 0 0 0 2em;\r\n  display: flex;\r\n  flex-direction: column;\r\n  row-gap: 0.3em;\r\n\r\n  @media(max-width: 600px) {\r\n    padding: 1em 1em 2em 1em;\r\n    text-align: center;\r\n    grid-column: 1/3;\r\n    font-size: 3.5em;\r\n  }\r\n`\r\n\r\nexport const Name = styled.span`\r\n  font-weight: 600;\r\n  letter-spacing: 2px;\r\n\r\n  @media(max-width: 600px) {\r\n    font-size: 0.8em;\r\n  }\r\n`\r\n\r\nexport const Description = styled.span`\r\n  font-size: 0.25em;\r\n  font-weight: 100;\r\n  max-width: 50ch;\r\n  letter-spacing: 1px;\r\n`","import Typewriter from 'typewriter-effect';\r\nimport { IntroductionContainer, Name, Description } from './Introduction.style';\r\n\r\nconst getRandomNumberInRange = (min, max) => {\r\n  return Math.ceil((Math.random() * (max - min) + min));\r\n}\r\n\r\nconst misSpell = (string) => {\r\n  const position = getRandomNumberInRange(1, string.length - 1)\r\n\r\n  const misSpelledString = `${string.slice(0, position)}bd`\r\n  const rest = string.slice(position, string.length)\r\n\r\n  return [ misSpelledString, rest ]\r\n}\r\n\r\nconst Introduction = () => {\r\n  const [ misSpelledString, rest ] = misSpell(\"Adam Jałocha\")\r\n\r\n  return (\r\n    <IntroductionContainer>\r\n      <Name>\r\n        <Typewriter\r\n          onInit={(typewriter) => {\r\n            typewriter\r\n              .changeDelay(80)\r\n              .typeString(misSpelledString)\r\n              .pauseFor(100)\r\n              .deleteChars(2)\r\n              .typeString(rest)\r\n              .pauseFor(1000)\r\n              .callFunction(state => state.elements.cursor.style.display = \"none\")\r\n              .start()\r\n          }}\r\n        />\r\n      </Name>\r\n      <Description>\r\n        I am a front-end developer who use react to accomplish things.\r\n      </Description>\r\n    </IntroductionContainer>\r\n  )\r\n}\r\n\r\nexport default Introduction","export default __webpack_public_path__ + \"static/media/github.c5ac6b5f.svg\";","export default __webpack_public_path__ + \"static/media/mail.dc3b5a36.svg\";","export default __webpack_public_path__ + 